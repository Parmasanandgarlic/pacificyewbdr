# ─── Apify (Google Maps business discovery) ────────────────────────────────
APIFY_TOKEN=

# ─── OpenRouter (AI qualify + draft emails) ───────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: which model to use. Defaults to a FREE model if unset.
OPENROUTER_MODEL=tencent/hy3:free

# ─── Google Sheets (lead storage) ──────────────────────────────────────────
# Name of the Google Sheet (create it once, share it with the service account email)
GOOGLE_SHEET_NAME=Pacific Yew Outbound CRM
# Spreadsheet ID from the Sheet URL (docs.google.com/spreadsheets/d/ID/edit)
GOOGLE_SHEET_ID=1yOvQ4kLabFwZaD2RRlPcTzRJbz2ZakHipbZsADqzI1k
# Path to the service-account JSON (keep this file out of git!)
GOOGLE_SHEET_CREDS=creds/service_account.json
# Tab/worksheet name inside the Sheet
GOOGLE_SHEET_TAB=Leads

# ─── Zoho Mail (send approved drafts + CASL unsubscribe inbox) ──────────────
# One Zoho mailbox does both: sends the CEMs AND receives UNSUBSCRIBE replies
# (the CASL scanner polls it via IMAP at imap.zoho.com:993).
# IMPORTANT: use an APP-SPECIFIC password, NOT your Zoho login password.
# Generate it at accounts.zoho.com → Security → Application-Specific Passwords.
# IMAP/POP must be enabled for the mailbox (mail.zoho.com → Settings →
# Mail Accounts → contact@pacificyew.pro → IMAP access: Enable).
GMAIL_USER=contact@pacificyew.pro
GMAIL_APP_PASSWORD=<Zoho app-specific password>
# Where replies (incl. UNSUBSCRIBE) land. Defaults to GMAIL_USER (same Zoho box).
REPLY_TO_EMAIL=

# ─── Sender identity (REQUIRED for CASL-compliant sending) ─────────────────
# Canada's anti-spam law requires your name, a physical mailing address, and an
# unsubscribe path in every commercial email. The bot REFUSES to send if
# SENDER_ADDRESS is blank. Use any real address you can receive mail at.
SENDER_NAME=Pacific Yew Automations
SENDER_INDIVIDUAL=Michael Goulden
SENDER_ADDRESS=
SENDER_WEBSITE=https://pacificyew.pro
# Optional second contact method for the footer (phone). Falls back to website.
SENDER_PHONE=
# Safety caps
SEND_LIMIT=20
QUERIES_PER_RUN=6
