# ─── Apify (Google Maps business discovery) ────────────────────────────────
APIFY_TOKEN=

# ─── OpenRouter (AI qualify + draft emails) ───────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: which model to use. Defaults to a FREE model if unset.
OPENROUTER_MODEL=tencent/hy3:free

# ─── Google Sheets (lead storage) ──────────────────────────────────────────
# Name of the Google Sheet (create it once, share it with the service account email)
GOOGLE_SHEET_NAME=Pacific Yew Outbound CRM
# Spreadsheet ID from the Sheet URL (docs.google.com/spreadsheets/d/ID/edit)
GOOGLE_SHEET_ID=1yOvQ4kLabFwZaD2RRlPcTzRJbz2ZakHipbZsADqzI1k
# Path to the service-account JSON (keep this file out of git!)
GOOGLE_SHEET_CREDS=creds/service_account.json
# Tab/worksheet name inside the Sheet
GOOGLE_SHEET_TAB=Leads

# ─── Gmail (send approved drafts) ──────────────────────────────────────────
# Gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Where replies land (your real domain inbox)
REPLY_TO_EMAIL=contact@pacificyew.pro
